# Sub-justfile for fauxput's VM dev harness.

set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

HERE := source_directory()
VKMS_SRC := env_var_or_default("VKMS_SRC", "")

default:
    @just --list --justfile {{ HERE }}/justfile

# Bring up a Fedora VM with vkms-edid-dkms loaded.
vm-up flavor="gnome":
    incus init images:fedora/44/cloud fauxput-test-{{ flavor }} --vm \
        --config user.user-data="$(cat {{ HERE }}/fedora-{{ flavor }}.yaml)" \
        --config limits.cpu=12 --config limits.memory=4GiB
    incus config device add fauxput-test-{{ flavor }} vkms-src disk \
        source={{ VKMS_SRC }} path=/mnt/vkms-src
    incus config device add fauxput-test-{{ flavor }} fauxput-src disk \
        source={{ HERE }}/.. path=/mnt/fauxput-src
    incus start fauxput-test-{{ flavor }}
    @just _wait-agent {{ flavor }}
    @echo "==> cloud-init provisioning"
    -incus exec fauxput-test-{{ flavor }} -- cloud-init status --wait
    incus restart fauxput-test-{{ flavor }}
    @just _wait-agent {{ flavor }}
    @just _wait-de-{{ flavor }}
    @just vm-install {{ flavor }}
    @just vm-snapshot {{ flavor }}

# Take or refresh the `ready` snapshot.
vm-snapshot flavor="gnome":
    -incus snapshot delete fauxput-test-{{ flavor }} ready 2>/dev/null
    incus snapshot create fauxput-test-{{ flavor }} ready

# Restore the VM to the `ready` snapshot. Wipes any runtime state.
vm-reset flavor="gnome":
    -incus stop fauxput-test-{{ flavor }} --force
    incus snapshot restore fauxput-test-{{ flavor }} ready
    incus start fauxput-test-{{ flavor }}
    @just _wait-agent {{ flavor }}

# Copy the host-built fauxput binary into the VM and setcap it.
vm-install flavor="gnome":
    cd {{ HERE }}/.. && just build
    incus file push {{ HERE }}/../target/release/fauxput fauxput-test-{{ flavor }}/usr/local/bin/fauxput --mode=0755
    incus exec fauxput-test-{{ flavor }} -- setcap cap_dac_override+ep /usr/local/bin/fauxput

# Shell into the VM as the test user.
vm-shell flavor="gnome":
    incus exec fauxput-test-{{ flavor }} -- sudo -iu test

# Rebuild vkms-edid-dkms inside the VM after editing $VKMS_SRC.
vm-vkms-rebuild flavor="gnome":
    incus exec fauxput-test-{{ flavor }} -- bash -c '\
        -dkms remove -m vkms-edid -v 0.1 --all 2>/dev/null; \
        rm -rf /usr/src/vkms-edid-0.1; \
        cp -rT /mnt/vkms-src /usr/src/vkms-edid-0.1; \
        dkms add -m vkms-edid -v 0.1; \
        dkms install -m vkms-edid -v 0.1'
    incus restart fauxput-test-{{ flavor }}
    @just _wait-agent {{ flavor }}
    @just _wait-de-{{ flavor }}

# Tear down the VM.
vm-down flavor="gnome":
    incus delete --force fauxput-test-{{ flavor }}

[private]
_wait-agent flavor:
    @echo "==> waiting for incus agent ({{ flavor }})"
    until incus exec fauxput-test-{{ flavor }} -- true 2>/dev/null; do sleep 2; done

[private]
_wait-de-gnome:
    @echo "==> waiting for GDM"
    until incus exec fauxput-test-gnome -- systemctl is-active --quiet gdm 2>/dev/null; do sleep 5; done

[private]
_wait-de-sway:
    @echo "==> waiting for sway session"
    until incus exec fauxput-test-sway -- pgrep -u test -x sway >/dev/null 2>&1; do sleep 5; done
